# runeflow environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets — it is listed in .gitignore.

# ── Required API keys ───────────────────────────────────────────────────────

# ENTSO-E Transparency Platform API key
# Register at: https://transparency.entsoe.eu/
ENTSOE=your_entsoe_api_key_here

# NED (Nationaal Energie Dashboard) API key — required for NL supplemental data
# Register at: https://ned.nl/
NED=your_ned_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# Market zone (default: NL)
# Supported: NL, DE_LU
ZONE=NL

# Tariff provider for the JSON export (default: wholesale)
# Used to look up the correct surcharge/markup applied on top of spot prices
TARIFF_PRICE_PROVIDER=wholesale

# Host directory where tariffs.json and the uncertainty plot are written
# Served via runeflow-server at http://localhost:8080/tariffs.json
TARIFF_OUTPUT_DIR=./outputs

# HTTP port for the nginx tariff server (default: 8080)
TARIFF_SERVER_PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Override the cache directory (default: ~/.cache/runeflow on Linux,
# respects XDG_CACHE_HOME if set)
# CACHE_DIR=/var/cache/runeflow

# ── Intel profile only ───────────────────────────────────────────────────────

# DRI render group GID on the host (for Intel GPU passthrough)
# Find with:  getent group render | cut -d: -f3
RENDER_GID=105
