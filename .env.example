# runeflow environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets — it is listed in .gitignore.

# ── Required API keys ───────────────────────────────────────────────────────

# ENTSO-E Transparency Platform API key
# Register at: https://transparency.entsoe.eu/
ENTSOE=your_entsoe_api_key_here

# NED (Nationaal Energie Dashboard) API key — required for NL supplemental data
# Register at: https://ned.nl/
NED=your_ned_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# Market zones to run (default: all 47 supported zones).
# Set to a comma-separated subset to run fewer zones and save time/resources.
# Supported zones: AT, BA, BE, BG, CH, CY, CZ, DE_LU, DK_1, DK_2, EE, ES, FI, FR, GB,
#                  GR, HR, HU, IE, IT_CNOR, IT_CSUD, IT_NORD, IT_SARD, IT_SICI, IT_SUD,
#                  LT, LV, ME, MK, MT, NL, NO_1, NO_2, NO_3, NO_4, NO_5, PL, PT, RO, RS,
#                  SE_1, SE_2, SE_3, SE_4, SI, SK, XK
# ZONES=NL,DE_LU

# Tariff provider for the JSON export (default: wholesale)
# Used to look up the correct surcharge/markup applied on top of spot prices
TARIFF_PRICE_PROVIDER=wholesale

# Host directory where tariffs.json and the site output are written
TARIFF_OUTPUT_DIR=./outputs

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Override the cache directory (default: ~/.cache/runeflow on Linux,
# respects XDG_CACHE_HOME if set)
# CACHE_DIR=/var/cache/runeflow

# ── Self-hosted Open-Meteo (docker compose --profile open-meteo) ─────────────

# Both deterministic forecast and probabilistic ensemble can be self-hosted.
# Data is downloaded directly from ECMWF open-data servers (free, no API key).
# The entrypoint script handles downloading and periodic refresh automatically.
#
# Start the service:  docker compose --profile open-meteo up -d
#
# Point runeflow at the local container by uncommenting these lines:
# OPENMETEO_FORECAST_API=http://open-meteo:8080/v1/forecast
# OPENMETEO_ENSEMBLE_API=http://open-meteo:8080/v1/ensemble
#
# Or use OPENMETEO_BASE_URL to override all three endpoints at once
# (forecast + ensemble + historical archive; archive requires separate ERA5 setup):
# OPENMETEO_BASE_URL=http://open-meteo:8080
#
# Tune the download behaviour (optional):
# OPEN_METEO_SYNC_DOMAINS=ifs025,ifs025_ensemble   # domains to download
# OPEN_METEO_SYNC_INTERVAL=21600                    # refresh every 6 hours (ECMWF schedule)
# OPEN_METEO_CONCURRENT=4                           # download workers
#
# Disk usage estimates per sync cycle:
#   ifs025            ~500 MB   (deterministic forecast, /v1/forecast)
#   ifs025_ensemble   ~5–15 GB  (50-member ensemble, /v1/ensemble)
#   ifs04_ensemble    ~2–5 GB   (0.4° ensemble — lighter but lower resolution)
#
# The first ensemble download takes several minutes. The API server starts
# immediately but returns empty data until the download finishes — runeflow
# will fall back to the public API on error and retry.

# ── Production — Cloudflare Tunnel (docker compose --profile tunnel) ─────────

# Tunnel token from Zero Trust → Networks → Tunnels → your tunnel → Configure.
# Required to start the cloudflared service.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── Production — Docker image (pulled from GHCR nightly by deploy-poll.sh) ───

# Pre-built image published by the publish.yml GitHub Actions workflow.
# On first deploy: docker compose pull
RUNEFLOW_IMAGE=ghcr.io/sikerdebaard/runeflow:latest

# Intel-optimised variant (only used with --profile intel).
# RUNEFLOW_IMAGE_INTEL=ghcr.io/sikerdebaard/runeflow-intel:latest

# Path where the repo is checked out on the production server.
# Used by scripts/deploy-poll.sh (default: /opt/runeflow).
DEPLOY_PATH=/opt/runeflow

# ── Intel profile only ───────────────────────────────────────────────────────

# DRI render group GID on the host (for Intel GPU passthrough)
# Find with:  getent group render | cut -d: -f3
RENDER_GID=105
