# runeflow environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets — it is listed in .gitignore.

# ── Required API keys ───────────────────────────────────────────────────────

# ENTSO-E Transparency Platform API key
# Register at: https://transparency.entsoe.eu/
ENTSOE=your_entsoe_api_key_here

# NED (Nationaal Energie Dashboard) API key — required for NL supplemental data
# Register at: https://ned.nl/
NED=your_ned_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# Market zone (default: NL)
# Supported: NL, DE_LU
ZONE=NL

# Tariff provider for the JSON export (default: wholesale)
# Used to look up the correct surcharge/markup applied on top of spot prices
TARIFF_PRICE_PROVIDER=wholesale

# Host directory where tariffs.json and the site output are written
TARIFF_OUTPUT_DIR=./outputs

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Override the cache directory (default: ~/.cache/runeflow on Linux,
# respects XDG_CACHE_HOME if set)
# CACHE_DIR=/var/cache/runeflow

# ── Production — Cloudflare Tunnel (docker compose --profile tunnel) ─────────

# Tunnel token from Zero Trust → Networks → Tunnels → your tunnel → Configure.
# Required to start the cloudflared service.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── Production — Docker image (pulled from GHCR nightly by deploy-poll.sh) ───

# Pre-built image published by the publish.yml GitHub Actions workflow.
# On first deploy: docker compose pull
RUNEFLOW_IMAGE=ghcr.io/sikerdebaard/runeflow:latest

# Intel-optimised variant (only used with --profile intel).
# RUNEFLOW_IMAGE_INTEL=ghcr.io/sikerdebaard/runeflow-intel:latest

# Path where the repo is checked out on the production server.
# Used by scripts/deploy-poll.sh (default: /opt/runeflow).
DEPLOY_PATH=/opt/runeflow

# ── Intel profile only ───────────────────────────────────────────────────────

# DRI render group GID on the host (for Intel GPU passthrough)
# Find with:  getent group render | cut -d: -f3
RENDER_GID=105
